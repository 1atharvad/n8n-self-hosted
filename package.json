{
  "name": "n8n-deploy",
  "version": "1.0.0",
  "description": "Self deployment for n8n",
  "keywords": [
    "n8n",
    "workflows"
  ],
  "license": "ISC",
  "author": "Atharva Devasthali",
  "type": "commonjs",
  "main": "index.js",
  "scripts": {
    "test": "jest --passWithNoTests",
    "build-n8n-nodes": "npx rimraf ./n8n-data/custom && tsc && gulp",
    "pip-install": "pip3.11 install -r requirements.txt",
    "add-pkg": "sh -c 'pip3.11 install \"$0\" && echo \"$(pip3.11 freeze | grep ^$0==)\" >> requirements.txt'",
    "lint:api": "cd api && ./venv/bin/python -m isort . && ./venv/bin/python -m black . && ./venv/bin/python -m ruff check .",
    "lint:admin": "cd admin-api/frontend && npm run lint",
    "ansible:setup:single": "CI_SSH_PUBKEY=\"$(cat ~/.ssh/id_ed25519.pub)\" ansible-playbook -i ansible/inventory/single.yml ansible/playbooks/setup.yml",
    "ansible:setup:multi": "CI_SSH_PUBKEY=\"$(cat ~/.ssh/id_ed25519.pub)\" ansible-playbook -i ansible/inventory/multi/ ansible/playbooks/setup.yml",
    "ansible:deploy:single": "ansible-playbook -i ansible/inventory/single.yml ansible/playbooks/deploy.yml",
    "ansible:deploy:multi": "ansible-playbook -i ansible/inventory/multi/ ansible/playbooks/deploy.yml",
    "ansible:rollback:single": "ansible-playbook -i ansible/inventory/single.yml ansible/playbooks/rollback.yml",
    "ansible:rollback:multi": "ansible-playbook -i ansible/inventory/multi/ ansible/playbooks/rollback.yml",
    "docker-up:dev": "sh sh_files/setup_n8n_files.sh && HOST_PROJECT_DIR=$(pwd) docker compose --env-file .env -f docker/docker-compose.dev.yml up --build -d",
    "docker-down:dev": "HOST_PROJECT_DIR=$(pwd) docker compose --env-file .env -f docker/docker-compose.dev.yml down",
    "docker:dev": "npm run docker-down:dev && rm -rf loki-data/* && npm run docker-up:dev",
    "docker-rm-cache": "docker container prune -f && docker image prune -a -f && docker volume prune -f && docker builder prune -a -f",
    "pull-workflows": "bash sh_files/backup_n8n_workflows.sh",
    "pull-workflows:force": "bash sh_files/backup_n8n_workflows.sh --force",
    "pull-workflows:commit": "bash sh_files/backup_n8n_workflows.sh --commit",
    "pull-workflows:force-commit": "bash sh_files/backup_n8n_workflows.sh --force --commit",
    "push-workflows": "bash sh_files/upload_n8n_workflows.sh"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "gulp": "^5.0.0",
    "jest": "^30.1.1",
    "ts-jest": "^29.4.1",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  }
}