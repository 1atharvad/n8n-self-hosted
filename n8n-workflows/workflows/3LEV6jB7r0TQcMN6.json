        "inputSchema": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"N8N Email Output Schema\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"subject\": {\n      \"type\": \"string\",\n      \"description\": \"Email subject line\",\n      \"minLength\": 1,\n      \"maxLength\": 200\n    },\n    \"body\": {\n      \"type\": \"string\",\n      \"description\": \"Email body content\",\n      \"minLength\": 1\n    }\n  },\n  \"required\": [\"subject\", \"body\"],\n  \"additionalProperties\": false\n}"
