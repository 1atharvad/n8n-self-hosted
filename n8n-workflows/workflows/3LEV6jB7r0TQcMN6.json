        "html": "<!DOCTYPE html>\n<html>\n<head>\n    <style>\n        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }\n        .container { max-width: 600px; margin: 0 auto; padding: 20px; }\n        .header { background: #ff4757; color: white; padding: 15px; text-align: center; border-radius: 5px; }\n        .content { background: #f8f9fa; padding: 20px; margin: 15px 0; border-radius: 5px; }\n        .error-info { background: white; padding: 15px; margin: 10px 0; border-left: 4px solid #007bff; }\n        .label { font-weight: bold; color: #666; }\n        .value { color: #333; margin-bottom: 10px; }\n    </style>\n</head>\n<body>\n    <div class=\"container\">\n        <div class=\"header\">\n            <h2>🚨 Workflow Error Alert</h2>\n            <p>n8n Automation Team</p>\n        </div>\n\n        <div class=\"content\">\n            <div class=\"error-info\">\n                <div class=\"label\">Error Details:</div>\n                <div class=\"value\">{{ $json.output.body }}</div>\n            </div>\n\n            <p style=\"color: #666; font-size: 12px; text-align: center;\">\n                Automated notification • Generated at: {{DateTime.now().toFormat('yyyy-MM-dd HH:mm:ss')}}\n            </p>\n        </div>\n    </div>\n</body>\n</html>"
