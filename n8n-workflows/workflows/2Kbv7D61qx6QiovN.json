        "jsCode": "const maxPages = $input.first().json.maxPages;\nconst pages_scrapped = $('Save Variables').first().json.pages_scrapped;\n\nreturn [...Array(maxPages).keys()].map(x => {\n  return {\n    json: {\n      start: (pages_scrapped + x) * 10,\n      query: $input.first().json.query,\n      before: $input.first().json.before,\n      after: $input.first().json.after\n    }\n  }\n});"
