      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  const site = item.json.site;\n  const inurl = item.json.inurl;\n  const keywords = item.json.keywords;\n  \n  item.json.query = `\n    ${site ? `site:${item.json.site}` : ''}\n    ${inurl ? ` inurl:${inurl}` : ''}\n    ${keywords ? ` ${keywords}` : ''}\n  `.replace(/\\n/g, '').replace(/\\s{2,}/g, ' ');\n}\n\nreturn $input.all();"
      },
