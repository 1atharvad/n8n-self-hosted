    {
      "parameters": {
        "jsCode": "const substrings = [\"hiring\", \"in\", \"|\"];\n\nreturn $input.all()\n  .filter(item => {\n    const title = item.json.pagemap?.metatags?.[0]?.['twitter:title'] || '';\n    return substrings.every(sub => title.includes(sub));\n  })\n  .map(item => {\n    const title = item.json.pagemap.metatags[0]['twitter:title'];\n    const titleParts = title.split(' hiring ');\n    const company_name = titleParts[0] || '';\n\n    let position = '';\n    let location = '';\n    if (titleParts[1]) {\n      const titleSubParts = titleParts[1].split(' |')[0].split(' in ');\n      position = titleSubParts[0] || '';\n      location = titleSubParts[1] || '';\n    }\n\n    return {\n      json: {\n        title: title,\n        company_name: company_name,\n        position: position,\n        location: location,\n        link: item.json.link\n      }\n    };\n  });"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -960,
        688
      ],
      "id": "3eb55112-6c6c-40be-b2bc-6b9525873ade",
      "name": "Extract Data"
    },
    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  const title = item.json.pagemap?.metatags?.[0]?.['twitter:title']\n      || item.json.pagemap?.metatags?.[0]?.['og:title']\n      || item.json.title;\n  return {\n    json: {\n      title: title,\n      link: item.json.link\n    }\n  }\n});"
      },
