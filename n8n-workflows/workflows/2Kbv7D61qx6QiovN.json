    {
      "parameters": {
        "jsCode": "let jobPortal;\n\nif ($input.first().json.scrape_by_weekday) {\n  const dayOfWeek = $input.first().json.weekday;\n  \n  switch (dayOfWeek) {\n    case \"Monday\":\n      jobPortal = \"Foundit\";\n      break;\n    case \"Tuesday\":\n      jobPortal = \"Naukri\";\n      break;\n    case \"Wednesday\":\n      jobPortal = \"Internshala\";\n      break;\n    case \"Thursday\":\n      jobPortal = \"FresherWorld\";\n      break;\n    case \"Friday\":\n      jobPortal = \"Foundit\";\n      break;\n    case \"Saturday\":\n      jobPortal = \"LinkedIn\";\n      break;\n    case \"Sunday\":\n      jobPortal = \"LinkedIn\";\n      break;\n    default:\n      jobPortal = \"\";\n      break;\n  }\n} else {\n  jobPortal = $input.first().json.job_portal;\n}\n\nreturn {\n  json: {\n    job_portal: jobPortal,\n    maxPages: Math.ceil($input.first().json.num_of_jobs / 10)\n  }\n};"
      },
