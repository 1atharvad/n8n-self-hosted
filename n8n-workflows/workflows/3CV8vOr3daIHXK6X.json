    {
      "parameters": {
        "schemaType": "manual",
        "inputSchema": "{\n  \"$schema\": \"http://json-schema.org/draft-07/schema#\",\n  \"title\": \"Job Posting News Segment\",\n  \"type\": \"object\",\n  \"properties\": {\n    \"segment_title\": {\n      \"type\": \"string\",\n      \"description\": \"Concise title for this job segment, e.g., 'Careers Update' or 'Job Spotlight'.\",\n      \"minLength\": 1,\n      \"maxLength\": 100\n    },\n    \"job_overview\": {\n      \"type\": \"string\",\n      \"description\": \"Precise description of the role, company, location, and responsibilities.\",\n      \"minLength\": 1\n    },\n    \"qualifications_requirements\": {\n      \"type\": \"string\",\n      \"description\": \"Summary of necessary skills, experience, and education for the role.\",\n      \"minLength\": 1\n    },\n    \"skills_required\": {\n      \"type\": \"string\",\n      \"description\": \"List or short paragraph of specific technical or soft skills needed.\",\n      \"minLength\": 1\n    },\n    \"benefits_perks\": {\n      \"type\": \"string\",\n      \"description\": \"Outline any notable advantages or benefits of the position.\",\n      \"minLength\": 1\n    },\n    \"application_details\": {\n      \"type\": \"string\",\n      \"description\": \"Instructions on how to apply, with reference to 'link below' instead of including actual URLs.\",\n      \"minLength\": 1\n    }\n  },\n  \"required\": [\n    \"segment_title\",\n    \"job_overview\",\n    \"qualifications_requirements\",\n    \"skills_required\",\n    \"benefits_perks\",\n    \"application_details\"\n  ],\n  \"additionalProperties\": false\n}",
        "autoFix": true
      },
