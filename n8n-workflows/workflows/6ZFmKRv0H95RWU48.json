    {
      "parameters": {
        "jsCode": "const startTimeString = $input.first().json.start_time;\nconst endTimeString = $input.first().json.end_time;\nconst timeZone = $input.first().json.timezone;\nconst now = new Date($now);\n\n// Map timezones to offsets\nconst timezoneOffsets = {\n  'Asia/Kolkata': '+05:30',\n  'America/New_York': '-04:00',\n  'America/Chicago': '-05:00',\n  'America/Denver': '-06:00',\n  'America/Los_Angeles': '-07:00',\n  'UTC': '+00:00',\n};\n\nconst offsetString = timezoneOffsets[timeZone] || '+00:00';\nconst offsetParts = offsetString.match(/([+-])(\\d{2}):(\\d{2})/);\nconst sign = offsetParts[1] === '+' ? 1 : -1;\nconst offsetMinutes = sign * (parseInt(offsetParts[2]) * 60 + parseInt(offsetParts[3]));\nconst currentOffsetTime = new Date(now.getTime() + offsetMinutes * 60 * 1000);\n\nconst pad = (n) => String(n).padStart(2, '0');\nconst yyyy = currentOffsetTime.getFullYear();\nconst mm = pad(currentOffsetTime.getMonth() + 1);\nconst dd = pad(currentOffsetTime.getDate());\nconst hh = pad(currentOffsetTime.getHours());\nconst mi = pad(currentOffsetTime.getMinutes());\nconst ss = pad(currentOffsetTime.getSeconds());\n\nconst [startHour, startMinute] = startTimeString.split(':').map(Number);\nconst [endHour, endMinute] = endTimeString.split(':').map(Number);\nconst isoStartTime = `${yyyy}-${mm}-${dd}T${pad(startHour)}:${pad(startMinute)}:00${offsetString}`;\nconst isoEndTime = `${yyyy}-${mm}-${dd}T${pad(endHour)}:${pad(endMinute)}:00${offsetString}`;\nconst isoCurrentTime = `${yyyy}-${mm}-${dd}T${hh}:${mi}:${ss}${offsetString}`;\n\nreturn [\n  {\n    json: {\n      user_id: $input.first().json.user_id,\n      selected_time_zone: timeZone,\n      formatted_date: $input.first().json.formattedDate,\n      start_time: `${pad(startHour)}:${pad(startMinute)}`,\n      end_time: `${pad(endHour)}:${pad(endMinute)}`,\n      iso_start_time: isoStartTime,\n      iso_end_time: isoEndTime,\n      current_time: `${hh}:${mi}`,\n      iso_current_time: isoCurrentTime\n    }\n  }\n];\n"
      },
