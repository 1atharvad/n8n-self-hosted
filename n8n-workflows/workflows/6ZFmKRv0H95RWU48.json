    {
      "parameters": {
        "jsCode": "const weekday_list = ['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];\n\nfor (const item of $input.all()) {\n  const date = item.json.currentDate;\n  const [year, month, day] = date.split('T')[0].split('-').map(Number);\n  item.json.formattedDate = date.split('T')[0]\n  item.json.weekday = weekday_list[new Date(year, month - 1, day).getUTCDay()]\n}\n\nreturn $input.all();"
      },
